# PostgreSQL connection string for production DB
# Option A (recommended): Railway auto-injects DATABASE_URL when you add a Postgres plugin — no manual entry needed.
# Option B (manual): Fill in your own Postgres credentials below.
ConnectionStrings__DefaultConnection=Host=YOUR_PG_HOST;Port=5432;Database=railway;Username=postgres;Password=YOUR_PG_PASSWORD

# JWT secret should be long and random (REQUIRED)
JwtSettings__SecretKey=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JwtSettings__Issuer=RecruitmentPlatformAPI
JwtSettings__Audience=RecruitmentPlatformClient
JwtSettings__ExpirationMinutes=1440

# API base URL when deployed (REQUIRED for links in emails/files)
EmailSettings__ApplicationUrl=https://YOUR_BACKEND.up.railway.app
FileStorage__BaseUrl=https://YOUR_BACKEND.up.railway.app

# Frontend URL(s) allowed by CORS. Separate multiple origins by comma.
FRONTEND_URLS=https://YOUR_FRONTEND.vercel.app,https://YOUR_FRONTEND.netlify.app

# Gmail SMTP for verification/reset emails (REQUIRED for auth email flows)
EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__SenderEmail=YOUR_EMAIL@gmail.com
EmailSettings__SenderPassword=YOUR_APP_PASSWORD
EmailSettings__SenderName=JobIntel
EmailSettings__EnableSsl=true
EmailSettings__FrontendUrl=https://YOUR_FRONTEND.vercel.app

# Optional toggles
APPLY_MIGRATIONS=true
ENABLE_HTTPS_REDIRECTION=false
